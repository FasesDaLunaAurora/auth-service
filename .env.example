# ==============================================================================
# Auth Service — variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores reais.
# Nenhuma variável aqui contém um segredo válido — apenas exemplos/placeholders.
# ==============================================================================

# --- Aplicação ---
APP_NAME=auth-service
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# --- Banco de dados (PostgreSQL 17, driver assíncrono asyncpg) ---
DATABASE_URL=postgresql+asyncpg://auth_service:auth_service@db:5432/auth_service
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_ECHO=false

# --- Redis (cache / rate limiting) ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
# Gere um valor forte, ex: `openssl rand -hex 32`. NUNCA use este exemplo em produção.
JWT_SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=auth-service

# --- Hash de senha ---
PASSWORD_HASH_SCHEME=bcrypt
BCRYPT_ROUNDS=12

# --- Política de conta / brute force ---
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# --- Rate limiting (rotas /auth/*) ---
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60

# --- MFA (TOTP) ---
MFA_ISSUER_NAME=AuthService
MFA_CODE_VALID_SECONDS=30

# --- SMTP (opcional em dev — deixe SMTP_HOST vazio para apenas logar e-mails) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@auth-service.local
SMTP_USE_TLS=true

# --- CORS ---
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
